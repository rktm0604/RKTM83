# RKTM83 — Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit real credentials.

# ── INFERENCE ─────────────────────────────────────────────────
# Groq API (free at console.groq.com — no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# Ollama runs locally — no key needed, just run: ollama serve
# OLLAMA_URL=http://localhost:11434   # default, change if different port

# ── EMAIL ─────────────────────────────────────────────────────
# Gmail app password (NOT your real password)
# Get one at: myaccount.google.com/apppasswords
RAKBOT_GMAIL_EMAIL=your_email@gmail.com
RAKBOT_GMAIL_PASSWORD=your_gmail_app_password

# ── GITHUB ────────────────────────────────────────────────────
# Optional but recommended — increases GitHub API rate limits
# Get one at: github.com/settings/tokens (read-only scope is enough)
GITHUB_TOKEN=your_github_token_here

# ── NOTIFICATIONS ─────────────────────────────────────────────
# Windows toast notifications — no key needed, just install win10toast-click
# Set to "false" to disable
RKTM83_NOTIFICATIONS=true
